---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Materials | ${SITE_TITLE}`} description="Practical resources, guides, and tools for navigating the digital landscape with your children." />
	</head>
	<body class="bg-gray-50 text-gray-900 font-sans leading-relaxed selection:bg-accent selection:text-navy">
		<Header />
		<main class="max-w-4xl mx-auto px-6 py-12 md:py-20">
			<div class="mb-16 border-b border-gray-200 pb-8">
				<h1 class="text-4xl md:text-5xl font-extrabold text-navy tracking-tight mb-4">Materials & Resources</h1>
				<p class="text-xl text-gray-600 max-w-2xl">
					Evergreen, practical resources for parents and educators to help build healthy digital habits.
				</p>
			</div>

			<div class="grid gap-8">
				<!-- Resource Card 1: Family Link Guide -->
				<div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 md:p-8 flex flex-col md:flex-row gap-6 items-start hover:shadow-md transition-shadow duration-200">
					<div class="bg-navy/10 p-4 rounded-xl text-navy shrink-0">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
						</svg>
					</div>
					<div class="flex-1">
						<div class="flex flex-wrap items-center gap-3 mb-3">
							<h2 class="text-2xl font-bold text-navy m-0">The Google Family Link Guide</h2>
							<span class="text-xs font-bold bg-gray-100 text-gray-600 px-3 py-1 rounded-full border border-gray-200">Coming soon</span>
						</div>
						<p class="text-gray-600 mb-5 text-lg">A complete, step-by-step guide to setting up and managing parental controls using Google Family Link. Everything you need to know without the technical jargon.</p>
						<span class="inline-flex items-center text-gray-400 font-semibold cursor-not-allowed">Read the guide <span class="ml-1">→</span></span>
					</div>
				</div>

				<!-- Resource Card 2: Recommended Books -->
				<div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 md:p-8 flex flex-col md:flex-row gap-6 items-start opacity-80">
					<div class="bg-accent/20 p-4 rounded-xl text-yellow-700 shrink-0">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />
						</svg>
					</div>
					<div class="flex-1">
						<div class="flex flex-wrap items-center gap-3 mb-3">
							<h2 class="text-2xl font-bold text-navy m-0">Recommended Reading</h2>
							<span class="text-xs font-bold bg-gray-100 text-gray-600 px-3 py-1 rounded-full border border-gray-200">Planned</span>
						</div>
						<p class="text-gray-600 text-lg">A curated list of essential books for navigating digital parenting and STEAM education.</p>
					</div>
				</div>

				<!-- Resource Card 3: Talks & Sessions -->
				<div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 md:p-8 flex flex-col md:flex-row gap-6 items-start opacity-80">
					<div class="bg-blue-50 p-4 rounded-xl text-blue-600 shrink-0">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
						</svg>
					</div>
					<div class="flex-1">
						<div class="flex flex-wrap items-center gap-3 mb-3">
							<h2 class="text-2xl font-bold text-navy m-0">Talks & Sessions</h2>
							<span class="text-xs font-bold bg-gray-100 text-gray-600 px-3 py-1 rounded-full border border-gray-200">Planned</span>
						</div>
						<p class="text-gray-600 text-lg">An archive of presentations, speaking engagements, and workshops on technology and education.</p>
					</div>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>