---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Welcome to Edulogia</h1>
			<p>
				<strong>Parents are their children's most important educators</strong>, but finding the right relationship with the digital world is complex.
			</p>
			<p>
				Edulogia helps make technology work for your family. We provide the guides, suggestions, and support needed to build healthy digital habits and leverage the best of what technology has to offer.
			</p>
			
			<div style="margin-top: 2rem; padding: 1.5rem; background-color: #f4f4f5; border-left: 4px solid #1e3a8a; border-radius: 4px;">
				<h3>Get Started</h3>
				<p>Explore our practical resources for navigating the digital landscape with your children.</p>
				<ul>
					<li><a href="#">The Google Family Link Guide (Coming soon)</a></li>
					<li><a href="/blog">Read the Blog</a></li>
				</ul>
			</div>
		</main>
		<Footer />
	</body>
</html>