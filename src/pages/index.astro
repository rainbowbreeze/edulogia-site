---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-gray-50 text-gray-900 font-sans leading-relaxed selection:bg-accent selection:text-navy">
		<Header />
		<main class="max-w-4xl mx-auto px-6 py-12 md:py-20">
			<div class="text-center mb-16">
				<h1 class="text-5xl font-extrabold text-navy tracking-tight mb-6">
					Welcome to <span class="text-accent underline decoration-8 underline-offset-4">Edulogia</span>
				</h1>
				<p class="text-xl md:text-2xl text-gray-700 max-w-3xl mx-auto font-medium">
					<strong>Parents are their children's most important educators</strong>, but finding the right relationship with the digital world is complex.
				</p>
			</div>
			
			<div class="prose prose-lg prose-blue mx-auto text-gray-700 mb-16">
				<p class="text-lg">
					Edulogia helps make technology work for your family. We provide the guides, suggestions, and support needed to build healthy digital habits and leverage the best of what technology has to offer.
				</p>
			</div>
			
			<div class="bg-white rounded-2xl shadow-xl overflow-hidden border border-gray-100 max-w-2xl mx-auto">
				<div class="bg-navy px-8 py-4 border-b-4 border-accent">
					<h3 class="text-2xl font-bold text-white m-0">Get Started</h3>
				</div>
				<div class="p-8">
					<p class="text-gray-600 mb-6 text-lg">Explore our practical resources for navigating the digital landscape with your children.</p>
					<ul class="space-y-4">
						<li>
							<a href="#" class="group flex items-center justify-between p-4 rounded-xl bg-gray-50 hover:bg-navy hover:text-white transition-all duration-200 border border-gray-100">
								<span class="font-semibold text-navy group-hover:text-accent">The Google Family Link Guide</span>
								<span class="text-sm font-medium bg-gray-200 text-gray-600 px-3 py-1 rounded-full group-hover:bg-white/20 group-hover:text-white">Coming soon</span>
							</a>
						</li>
						<li>
							<a href="/edulogia-site/blog" class="group flex items-center justify-between p-4 rounded-xl bg-gray-50 hover:bg-navy hover:text-white transition-all duration-200 border border-gray-100">
								<span class="font-semibold text-navy group-hover:text-accent">Read the Blog</span>
								<span class="text-accent">→</span>
							</a>
						</li>
					</ul>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>