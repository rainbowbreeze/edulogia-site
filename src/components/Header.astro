---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
const base = import.meta.env.BASE_URL;
---

<header class="bg-white shadow-sm sticky top-0 z-50 border-b border-gray-100">
	<nav class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
		<h2 class="text-2xl font-extrabold text-navy tracking-tight m-0">
			<a href={base} class="hover:text-accent transition-colors duration-200">{SITE_TITLE}</a>
		</h2>
		<div class="flex gap-6 items-center">
			<HeaderLink href={base}>Home</HeaderLink>
			<HeaderLink href={`${base}/materials`}>Materials</HeaderLink>
			<HeaderLink href={`${base}/blog`}>Blog</HeaderLink>
			<HeaderLink href={`${base}/about`}>About</HeaderLink>
		</div>
	</nav>
</header>